{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=orders.db"
  },
  "Jwt": {
    "Secret": "super-secret-key-for-order-management-system-2024-long-enough",
    "Issuer": "OrderManagement.API",
    "Audience": "OrderManagement.Client",
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
